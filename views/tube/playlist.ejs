<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wkt</title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
    <script src="/js/force-title.js"></script>
    <script src="/js/navigate.js"></script>
</head>
<body class="bg-gray-900 text-white">

<header class="bg-gray-800 p-4 flex justify-between items-center">
    <form action="/wkt/s" method="post" class="w-1/2" id="searchForm">
        <input type="text" name="q" id="searchbox" placeholder="検索" class="searchbox w-full p-2 rounded bg-gray-700 text-white">
    </form>
    <nav class="space-x-4">
        <a href="/wkt" class="text-gray-300 hover:text-white">ホーム</a>
        <a href="/wkt/trend" class="text-gray-300 hover:text-white">トレンド</a>
        <a href="/wkt/cl/fav" class="text-gray-300 hover:text-white">お気に入り</a>
        <a href="/wkt/cl/history" class="text-gray-300 hover:text-white">再生履歴</a>
    </nav>
</header>

<div class="container mx-auto p-3">

    <%# ===== 再生リストヘッダー ===== %>
    <div class="bg-gray-800 p-8 rounded-lg shadow-lg mt-4">
        <div class="flex flex-col md:flex-row items-start gap-6">
            <%# サムネイル %>
            <% const thumb = info.thumbnails?.[0]?.url || ''; %>
            <% if (thumb) { %>
            <div class="flex-shrink-0 w-full md:w-64">
                <img src="<%= thumb %>" alt="<%= info.title %>" class="w-full rounded-lg aspect-video object-cover">
            </div>
            <% } %>
            <%# メタ情報 %>
            <div class="flex-1 min-w-0">
                <h1 class="text-3xl font-bold mb-3"><%- info.title || '' %></h1>
                <% if (info.author) { %>
                <a href="/wkt/c/<%= info.author.id %>" class="flex items-center gap-3 mb-3 group w-fit">
                    <% if (info.author.thumbnails?.[0]?.url) { %>
                    <img src="<%= info.author.thumbnails[0].url %>" alt="<%= info.author.name %>" class="w-8 h-8 rounded-full">
                    <% } %>
                    <span class="text-gray-300 group-hover:text-white font-medium transition"><%= info.author.name || '' %></span>
                </a>
                <% } %>
                <% if (info.total_items) { %>
                <p class="text-gray-400 text-sm mb-2"><%= info.total_items %></p>
                <% } %>
                <% if (info.last_updated) { %>
                <p class="text-gray-500 text-sm mb-3"><%= info.last_updated %></p>
                <% } %>
                <% if (info.description) { %>
                <p class="text-gray-400 text-sm leading-relaxed line-clamp-3"><%- info.description %></p>
                <% } %>
            </div>
        </div>
    </div>

    <%# ===== 動画リスト ===== %>
    <div class="mt-6">
        <% if (items && items.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            <% items.forEach(item => { %>
            <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                <a href="/wkt/watch/<%= item.id %>?list=<%= playlistId %>" class="block relative group wkt-watch-link" data-video-id="<%= item.id %>" data-list="<%= playlistId %>">
                    <img loading="lazy"
                         src="/wkt/back/vi/<%= item.id %>/mqdefault.jpg"
                         alt="<%= item.title %>"
                         class="w-full h-auto rounded aspect-video object-cover">
                    <% if (item.duration) { %>
                    <span class="absolute bottom-1 right-1 bg-black bg-opacity-80 text-white text-xs px-1.5 py-0.5 rounded font-medium"><%= item.duration %></span>
                    <% } %>
                    <span class="absolute top-1 left-1 bg-black bg-opacity-60 text-white text-xs px-1.5 py-0.5 rounded"><%= item.index %></span>
                    <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                </a>
                <div class="mt-3">
                    <a href="/wkt/watch/<%= item.id %>?list=<%= playlistId %>" class="wkt-watch-link" data-video-id="<%= item.id %>" data-list="<%= playlistId %>">
                        <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 hover:text-blue-400 transition"><%= item.title %></p>
                    </a>
                    <% if (item.channelName) { %>
                    <a href="/wkt/c/<%= item.channelId || '' %>" class="text-gray-400 text-xs hover:text-gray-200 transition"><%= item.channelName %></a>
                    <% } %>
                    <% const meta = [item.views, item.published].filter(Boolean).join(' • '); %>
                    <% if (meta) { %>
                    <p class="text-gray-500 text-xs mt-0.5"><%= meta %></p>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
        <% } else { %>
        <p class="text-gray-400 py-12 text-center">動画がありません。</p>
        <% } %>
    </div>

    <div style="height:480px;" class="w-full max-w-3xl mx-auto mt-8">
        <script src="//accaii.com/wktplus/widget.js" async></script>
    </div>
</div>

</body>
</html>
